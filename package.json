{
  "name": "firecrawl-extension",
  "version": "1.0.0",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "plasmo dev --verbose",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Quickly Scrape/Crawl the current website & copy Markdown / JSON / HTML with Firecrawl.",
  "dependencies": {
    "@plasmohq/messaging": "^0.7.2",
    "@plasmohq/storage": "^1.15.0",
    "@tanstack/react-query": "^5.90.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remeda": "^2.32.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.22",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "plasmo": "^0.90.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "type": "module",
  "displayName": "Fireclaw - Firecrawl Extension",
  "manifest": {
    "permissions": [
      "activeTab",
      "tabs",
      "downloads",
      "storage"
    ],
    "host_permissions": [
      "https://api.firecrawl.dev/*"
    ]
  }
}
